# 국유공간든든 환경변수
# 클라이언트에 노출돼도 되는 값만 VITE_ 접두사. 비밀키는 prod에서 Worker secret 사용.

VITE_APP_NAME=국유공간든든

# Kakao 지도 JS 키 (도메인 제한이 걸리므로 클라 노출 허용)
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
VITE_KAKAO_JS_KEY=

# ── data.go.kr 키 (권장: Cloudflare Worker에만 보관) ─────────────────────────
# [권장] Worker 모드: 아래 VITE_PROXY_BASE만 채우면 dev/prod 모두 Worker 경유.
#        data.go.kr 키는 Worker secret(DATAGO_KEY)에만 — 브라우저엔 키가 안 실림.
#   - 로컬 Worker:  app/.dev.vars 에  DATAGO_KEY=발급키   →  npm run worker:dev (http://localhost:8787)
#                   VITE_PROXY_BASE=http://localhost:8787
#   - 배포 Worker:  wrangler secret put DATAGO_KEY  →  npm run worker:deploy
#                   VITE_PROXY_BASE=https://gukyu-space-proxy.<account>.workers.dev
VITE_PROXY_BASE=

# [폴백 전용] VITE_PROXY_BASE를 안 쓸 때만. dev Vite 프록시에 클라가 키를 부착(노출됨).
# Cloudflare에 키를 둘 거면 비워두세요.
VITE_DATAGO_KEY=

# ── OpenAI (AI 자연어 검색·자리 분석) ─────────────────────────
# [권장] Worker 모드: wrangler secret put OPENAI_KEY (클라 노출 0)
# [dev 전용] 로컬 테스트 시에만 아래에 키 입력(Vite 프록시가 Authorization 주입). 배포본엔 두지 말 것.
VITE_OPENAI_KEY=

# 배포 base 경로(GitHub Pages 등). 루트 배포면 '/'
VITE_BASE=/
